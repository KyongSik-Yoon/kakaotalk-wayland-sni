[Unit]
Description=StatusNotifier companion for KakaoTalk on Wine Wayland
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=@CMAKE_INSTALL_FULL_BINDIR@/kakaotalk-wayland-sni
EnvironmentFile=-%h/.config/kakaotalk-wayland-sni/config
Restart=on-failure
RestartSec=2

[Install]
WantedBy=graphical-session.target
